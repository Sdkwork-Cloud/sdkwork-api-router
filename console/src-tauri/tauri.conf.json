{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SDKWork API Console",
  "version": "0.1.0",
  "identifier": "com.sdkwork.api.console",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "bundle": {
    "active": true,
    "icon": [
      "../../apps/sdkwork-router-portal/src-tauri/icons/32x32.png",
      "../../apps/sdkwork-router-portal/src-tauri/icons/128x128.png",
      "../../apps/sdkwork-router-portal/src-tauri/icons/128x128@2x.png",
      "../../apps/sdkwork-router-portal/src-tauri/icons/icon.icns",
      "../../apps/sdkwork-router-portal/src-tauri/icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SDKWork API Console",
        "width": 1280,
        "height": 900
      }
    ]
  }
}
