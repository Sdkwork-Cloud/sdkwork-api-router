{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SDKWork Router Portal",
  "version": "0.1.0",
  "identifier": "com.sdkwork.router.portal",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "node ../../scripts/prepare-router-portal-desktop-runtime.mjs",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174/portal/"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../../bin/portal-rt/router-product/": "router-product/"
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SDKWork Router Portal",
        "width": 1440,
        "height": 960,
        "resizable": true,
        "decorations": false,
        "visible": false
      }
    ]
  }
}
