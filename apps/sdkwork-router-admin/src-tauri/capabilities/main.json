{
  "identifier": "main",
  "description": "Allows the local main admin window to control desktop window chrome and resolve the embedded router runtime base URL.",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:window:allow-close",
    "core:window:allow-is-maximized",
    "core:window:allow-maximize",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-unmaximize",
    "allow-runtime-base-url",
    "allow-install-api-router-client-setup",
    "allow-list-api-key-instances"
  ]
}
