SDKWORK_POSTGRES_DB=sdkwork_api_router
SDKWORK_POSTGRES_USER=sdkwork
SDKWORK_POSTGRES_PASSWORD=replace-with-db-password
SDKWORK_BOOTSTRAP_PROFILE=prod
SDKWORK_ADMIN_JWT_SIGNING_SECRET=replace-with-admin-jwt-secret
SDKWORK_PORTAL_JWT_SIGNING_SECRET=replace-with-portal-jwt-secret
SDKWORK_CREDENTIAL_MASTER_KEY=replace-with-credential-master-key
SDKWORK_METRICS_BEARER_TOKEN=replace-with-metrics-token
SDKWORK_BROWSER_ALLOWED_ORIGINS=http://localhost:3001

# Unified user-center server contract.
# builtin-local: keep a local user center inside this router deployment.
# sdkwork-cloud-app-api: delegate to the shared cloud app-api authority.
# external-user-center: delegate to a third-party user-center authority.
SDKWORK_USER_CENTER_MODE=builtin-local
SDKWORK_USER_CENTER_PROVIDER_KEY=sdkwork-api-router-local
SDKWORK_USER_CENTER_APP_ID=sdkwork-api-router
SDKWORK_USER_CENTER_LOCAL_API_BASE_PATH=/api/app/v1/user-center
SDKWORK_USER_CENTER_SQLITE_PATH=/opt/sdkwork/data/user-center.db
SDKWORK_USER_CENTER_DATABASE_URL=
SDKWORK_USER_CENTER_SCHEMA_NAME=
SDKWORK_USER_CENTER_TABLE_PREFIX=rp_uc_
SDKWORK_USER_CENTER_APP_API_BASE_URL=
SDKWORK_USER_CENTER_EXTERNAL_BASE_URL=
SDKWORK_USER_CENTER_SECRET_ID=
SDKWORK_USER_CENTER_SHARED_SECRET=
SDKWORK_USER_CENTER_AUTHORIZATION_HEADER_NAME=Authorization
SDKWORK_USER_CENTER_ACCESS_TOKEN_HEADER_NAME=Access-Token
SDKWORK_USER_CENTER_REFRESH_TOKEN_HEADER_NAME=Refresh-Token
SDKWORK_USER_CENTER_SESSION_HEADER_NAME=x-sdkwork-user-center-session-id
SDKWORK_USER_CENTER_AUTHORIZATION_SCHEME=Bearer
SDKWORK_USER_CENTER_ALLOW_AUTHORIZATION_FALLBACK_TO_ACCESS_TOKEN=true
SDKWORK_USER_CENTER_HANDSHAKE_FRESHNESS_WINDOW_MS=30000
